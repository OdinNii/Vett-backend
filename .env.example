# ── App ───────────────────────────────────────────────────────────────────────
DEBUG=false
SECRET_KEY=change-me-to-a-long-random-string-in-production

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://vett:vett@localhost:5432/vett

# ── Adzuna API ────────────────────────────────────────────────────────────────
# Register at https://developer.adzuna.com to get credentials
ADZUNA_APP_ID=your_adzuna_app_id
ADZUNA_API_KEY=your_adzuna_api_key

# ── Job Scanner ───────────────────────────────────────────────────────────────
SCAN_INTERVAL_HOURS=6
MAX_JOBS_PER_SCAN=50
MIN_FIT_SCORE=60

# ── CV ────────────────────────────────────────────────────────────────────────
MAX_CV_SIZE_MB=10

# ── Email (SendGrid) ──────────────────────────────────────────────────────────
# Register at https://sendgrid.com — create an API key with "Mail Send" access
SENDGRID_API_KEY=SG.your_sendgrid_api_key_here
SENDGRID_FROM_EMAIL=hello@vett.app
SENDGRID_FROM_NAME=Vett
